@model WebApplication15.Models.Appointment

@{
    ViewData["Title"] = "Add Appointment";
}

<div class="google-card">
    <h2 style="font-family:'Google Sans',sans-serif;font-size:22px;font-weight:400;margin-bottom:24px;color:#202124;">
        Add New Appointment
    </h2>

    @* Show server-side validation errors (Data Annotations + IValidatableObject) *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger" style="font-size:14px;border-radius:4px;">
            @Html.ValidationSummary(false, "", new { @class = "text-danger mb-0" })
        </div>
    }

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        @* ── Name (required, Use Case: "empty name" is invalid) ── *@
        <div class="mb-3">
            <label class="form-label" asp-for="Name">Title</label>
            <input class="google-input" asp-for="Name" placeholder="Add title" autofocus />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        @* ── Location ── *@
        <div class="mb-3">
            <label class="form-label" asp-for="Location">Location</label>
            <input class="google-input" asp-for="Location" placeholder="Add location" />
        </div>

        @* ── Start / End times (Use Case: "negative duration" is invalid) ── *@
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label" asp-for="StartTime">Start Time</label>
                <input class="google-input" asp-for="StartTime" type="datetime-local" />
                <span asp-validation-for="StartTime" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="EndTime">End Time</label>
                <input class="google-input" asp-for="EndTime" type="datetime-local" />
                <span asp-validation-for="EndTime" class="text-danger small"></span>
            </div>
        </div>

        @* ── Reminders (Use Case: "Any reminder selected by the user is added to the list of reminders") ── *@
        <div class="mb-4">
            <label class="form-label">Reminders</label>
            <div style="display:flex;flex-wrap:wrap;gap:10px;">
                @foreach (var (label, minutes) in new[]
                {
                    ("At time of event",  0),
                    ("5 min before",      5),
                    ("10 min before",    10),
                    ("15 min before",    15),
                    ("30 min before",    30),
                    ("1 hour before",    60),
                    ("1 day before",   1440)
                })
                {
                    <label class="reminder-chip">
                        <input type="checkbox"
                               name="selectedReminders"
                               value="@minutes"
                               style="display:none;" />
                        <span>🔔 @label</span>
                    </label>
                }
            </div>
            <small class="text-muted">Select one or more reminders (optional).</small>
        </div>

        @* ── Actions ── *@
        <div class="d-flex justify-content-end mt-4 gap-2">
            <a asp-action="Index" class="btn-outline">Cancel</a>
            <button type="submit" class="btn-google">Save</button>
        </div>
    </form>
</div>

@* ── Client-side reminder chip toggle (UX enhancement) ── *@
<style>
    .reminder-chip {
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        padding: 6px 14px;
        border-radius: 20px;
        border: 1px solid #dadce0;
        font-size: 13px;
        color: #3c4043;
        background: #fff;
        transition: background .15s, border-color .15s;
        user-select: none;
    }
    .reminder-chip:hover { background: #f1f3f4; }
    .reminder-chip.selected {
        background: #e8f0fe;
        border-color: #1a73e8;
        color: #1a73e8;
        font-weight: 500;
    }
</style>
<script>
    document.querySelectorAll('.reminder-chip').forEach(chip => {
        const cb = chip.querySelector('input[type=checkbox]');
        chip.addEventListener('click', () => {
            cb.checked = !cb.checked;
            chip.classList.toggle('selected', cb.checked);
        });
    });
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}