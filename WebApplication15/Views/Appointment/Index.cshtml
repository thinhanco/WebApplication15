@model IEnumerable<WebApplication15.Models.Appointment>

@{
    ViewData["Title"] = "Lịch biểu";
}

<style>
    .schedule-view {
        background: white;
        border-radius: 8px;
        box-shadow: 0 1px 2px 0 rgba(60,64,67,.3), 0 1px 3px 1px rgba(60,64,67,.15);
        overflow: hidden;
    }
    .schedule-header {
        background: #f1f3f4;
        padding: 16px 24px;
        font-weight: 500;
        font-size: 14px;
        color: #5f6368;
        border-bottom: 1px solid #e0e0e0;
    }
    .schedule-row {
        display: flex;
        padding: 12px 24px;
        border-bottom: 1px solid #e0e0e0;
        transition: background-color 0.2s;
        align-items: center;
    }
    .schedule-row:hover {
        background-color: #f8f9fa;
    }
    .schedule-row:last-child {
        border-bottom: none;
    }
    .time-col {
        width: 150px;
        color: #5f6368;
        font-size: 14px;
        font-weight: 500;
    }
    .event-col {
        flex: 1;
        display: flex;
        align-items: center;
    }
    .event-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background-color: #039be5;
        margin-right: 12px;
    }
    .event-details {
        display: flex;
        flex-direction: column;
    }
    .event-title {
        font-size: 15px;
        color: #3c4043;
        font-weight: 500;
        margin-bottom: 2px;
    }
    .event-location {
        font-size: 13px;
        color: #5f6368;
    }
    .empty-state {
        padding: 40px;
        text-align: center;
        color: #5f6368;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-family: 'Google Sans', sans-serif; font-size: 28px; color: #3c4043; font-weight: 400; margin: 0;">Lịch biểu của bạn</h2>
</div>

<div class="schedule-view">
    <div class="schedule-header">
        Sắp tới
    </div>
    
    @if (Model != null && Model.Any())
    {
        foreach (var appt in Model.OrderBy(a => a.StartTime))
        {
            <div class="schedule-row">
                <div class="time-col">
                    <div>@appt.StartTime.ToString("dd/MM/yyyy")</div>
                    <div style="font-size: 13px; color: #70757a;">@appt.StartTime.ToString("HH:mm") - @appt.EndTime.ToString("HH:mm")</div>
                </div>
                <div class="event-col">
                    <div class="event-dot"></div>
                    <div class="event-details">
                        <div class="event-title">@appt.Name</div>
                        @if (!string.IsNullOrEmpty(appt.Location))
                        {
                            <div class="event-location">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="#5f6368" style="vertical-align: text-bottom;"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"></path></svg>
                                @appt.Location
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="#dadce0" class="mb-3"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zM9 14H7v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2zm-8 4H7v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2z"></path></svg>
            <h4>Không có lịch hẹn nào sắp tới</h4>
            <p>Hãy tạo một cuộc hẹn mới để bắt đầu lên lịch cho công việc của bạn.</p>
        </div>
    }
</div>
