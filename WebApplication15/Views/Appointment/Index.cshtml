@model IEnumerable<WebApplication15.Models.Appointment>
@* Inject Service để lấy danh sách họp nhóm *@
@inject WebApplication15.Services.AppointmentService _service

@{
    ViewData["Title"] = "Lịch biểu";
    var groupMeetings = _service.GetAllGroupMeetings(); // Lấy dữ liệu từ Service (bao gồm dữ liệu Seed)
}

<style>
    .schedule-view {
        background: white;
        border-radius: 8px;
        box-shadow: 0 1px 2px 0 rgba(60,64,67,.3), 0 1px 3px 1px rgba(60,64,67,.15);
        overflow: hidden;
        margin-bottom: 30px;
    }
    .schedule-header {
        background: #f1f3f4;
        padding: 16px 24px;
        font-weight: 500;
        font-size: 14px;
        color: #5f6368;
        border-bottom: 1px solid #e0e0e0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .schedule-row {
        display: flex;
        padding: 12px 24px;
        border-bottom: 1px solid #e0e0e0;
        transition: background-color 0.2s;
        align-items: center;
    }
    .schedule-row:hover { background-color: #f8f9fa; }
    .time-col { width: 150px; color: #5f6368; font-size: 14px; font-weight: 500; }
    .event-col { flex: 1; display: flex; align-items: center; }
    .event-dot { width: 12px; height: 12px; border-radius: 50%; background-color: #039be5; margin-right: 12px; }
    .dot-group { background-color: #34a853; } /* Màu xanh lá cho họp nhóm */
    .event-details { display: flex; flex-direction: column; }
    .event-title { font-size: 15px; color: #3c4043; font-weight: 500; margin-bottom: 2px; }
    .empty-state { padding: 40px; text-align: center; color: #5f6368; }
</style>

<div class="mb-4">
    <h2 style="font-family: 'Google Sans', sans-serif; font-size: 28px; color: #3c4043; font-weight: 400; margin: 0;">Lịch biểu của bạn</h2>
</div>

<!-- PHẦN 1: LỊCH CÁ NHÂN -->
<div class="schedule-view">
    <div class="schedule-header">LỊCH CÁ NHÂN SẮP TỚI</div>
    
    @if (Model != null && Model.Any())
    {
        foreach (var appt in Model.OrderBy(a => a.StartTime))
        {
            <div class="schedule-row">
                <div class="time-col">
                    <div>@appt.StartTime.ToString("dd/MM/yyyy")</div>
                    <div style="font-size: 13px; color: #70757a;">@appt.StartTime.ToString("HH:mm") - @appt.EndTime.ToString("HH:mm")</div>
                </div>
                <div class="event-col">
                    <div class="event-dot"></div>
                    <div class="event-details">
                        <div class="event-title">@appt.Name</div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">Chưa có lịch cá nhân nào.</div>
    }
</div>

<!-- PHẦN 2: CUỘC HỌP NHÓM -->
<div class="schedule-view">
    <div class="schedule-header" style="color: #1e8e3e;">CUỘC HỌP NHÓM ĐANG DIỄN RA</div>
    
    @if (groupMeetings != null && groupMeetings.Any())
    {
        foreach (var g in groupMeetings)
        {
            <div class="schedule-row">
                <div class="time-col">
                    <div>@g.StartTime.ToString("dd/MM/yyyy")</div>
                    <div style="font-size: 13px; color: #70757a;">@g.StartTime.ToString("HH:mm") - @g.EndTime.ToString("HH:mm")</div>
                </div>
                <div class="event-col">
                    <div class="event-dot dot-group"></div>
                    <div class="event-details">
                        <div class="event-title">@g.Name</div>
                        <div style="font-size: 12px; color: #1e8e3e;">
                             @(g.Participants?.Count ?? 0) người tham gia
                        </div>
                    </div>
                </div>
                <div>
                    <form asp-action="JoinGroup" method="post">
                        <input type="hidden" name="meetingId" value="@g.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-success" style="border-radius: 15px;">Tham gia</button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">Không có cuộc họp nhóm nào.</div>
    }
</div>a
