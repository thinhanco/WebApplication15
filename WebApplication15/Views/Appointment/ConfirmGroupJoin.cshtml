@model WebApplication15.Models.GroupMeeting

@{
    ViewData["Title"] = "Tham gia họp nhóm";
    var proposedApp = ViewBag.ProposedAppointment as WebApplication15.Models.Appointment;
}

<div class="google-card border-top border-4 border-primary">
    <div class="d-flex align-items-center mb-3">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="#1a73e8" class="me-2"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"></path></svg>
        <h2 style="font-family: 'Google Sans', sans-serif; font-size: 20px; font-weight: 500; margin: 0; color: #1a73e8;">Họp nhóm đã tồn tại</h2>
    </div>
    
    <p style="font-size: 15px; color: #3c4043; margin-bottom: 20px;">
        Chúng tôi tìm thấy một cuộc họp nhóm <strong>"@Model.Name"</strong> đang diễn ra vào cùng thời điểm bạn vừa chọn 
        (@proposedApp?.StartTime.ToString("HH:mm") - @proposedApp?.EndTime.ToString("HH:mm")).
        <br/><br/>
        Bạn có muốn tham gia nhóm này thay vì tạo cuộc hẹn mới không?
    </p>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <!-- Nút từ chối -> Quay lại tạo bình thường hoặc hủy -->
        <a href="/Appointment/Create" class="btn-outline">Không, quay lại</a>
        
        <form asp-action="JoinGroup" method="post">
            <input type="hidden" name="meetingId" value="@Model.Id" />
            <button type="submit" class="btn-google">Đồng ý tham gia</button>
        </form>
    </div>
</div>